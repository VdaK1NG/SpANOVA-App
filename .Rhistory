newLabels <- function(x, dig.lab = 4){
lev <- levels(x)
pattern <- paste0("^[\\(\\[][-]*\\d*\\.\\d{",
dig.lab,
"}|,[-]*\\d*\\.\\d{",
dig.lab,
"}"
)
m <- gregexpr(pattern = pattern, levels(x))
y <- regmatches(lev, m)
y <- sapply(y, paste, collapse = "")
y <- paste0(y, substring(lev, nchar(lev)))
y
}
